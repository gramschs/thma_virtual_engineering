laeuft\n    if not laeuft:\n        return\n\n    if kugel.y <= KUGELRADIUS:\n        laeuft = False\n        kugel.y = KUGELRADIUS  # auf Boden \"setzen\"\n\n        print('--- Ergebnisse (numerisch) ---')\n        print(f'Fallzeit (Simulation):      {t_sim:.4f} s')\n        print(f'Aufprallgeschwindigkeit:    {abs(v_y):.4f} m/s')\n\n        t_analytisch = math.sqrt(2 * h_eff / G)\n        v_analytisch = G * t_analytisch\n        print('--- Ergebnisse (analytisch) ---')\n        print(f'Fallzeit (analytisch):      {t_analytisch:.4f} s')\n        print(f'Aufprallgeschwindigkeit:    {v_analytisch:.4f} m/s')\n\n    # zu große Zeitschritte vermeiden, sonst sieht man die\n    # animierte Bewegung nicht mehr\n    dt = min(time.dt, 1/120)\n    \n    # Euler-Cromer: erst Geschwindigkeit, dann Position\n    v_y        -= G * dt        # Schwerkraft: v_y wird negativer\n    kugel.y    += v_y * dt\n    t_sim      += dt\n\n    anzeige.text = f't = {t_sim:.3f} s | v = {abs(v_y):.3f} m/s'\n\napp.run()","position":{"start":{"line":118,"column":1},"end":{"line":184,"column":1}},"key":"mxeHDmL2o8"}],"class":"tip dropdown","key":"PIuxbTtTSE"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Übung 8.4 (✩✩)","position":{"start":{"line":187,"column":1},"end":{"line":187,"column":1}},"key":"cJshXhITZ8"}],"key":"xbYkE5gzNH"},{"type":"paragraph","position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"children":[{"type":"strong","position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"children":[{"type":"text","value":"Szene mit Führungsschienen aufbauen","position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"key":"utSnaeFHVi"}],"key":"tnKJMSX869"}],"key":"VvXE4aHIlr"},{"type":"paragraph","position":{"start":{"line":191,"column":1},"end":{"line":192,"column":1}},"children":[{"type":"text","value":"Bauen Sie eine statische Ursina-Szene, die den Startbereich der Kugelbahn\nmit zwei Führu