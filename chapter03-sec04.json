                       {effizienz:.2f}\")","position":{"start":{"line":167,"column":1},"end":{"line":223,"column":1}},"key":"Qg0H2gqjR8"},{"type":"paragraph","position":{"start":{"line":225,"column":1},"end":{"line":225,"column":1}},"children":[{"type":"text","value":"Erwartete Ausgabe:","position":{"start":{"line":225,"column":1},"end":{"line":225,"column":1}},"key":"nZkva6iCcm"}],"key":"OfnKDrtwJO"},{"type":"code","lang":"","value":"Qualitätsgewinn (Abweichungsverbesserung):    1.355\nRelative Rechenzeitänderung (downscale 4→2): -0.183\nEffizienz-Quotient:                          7.39","position":{"start":{"line":227,"column":1},"end":{"line":231,"column":1}},"key":"jX9mDTWwEb"},{"type":"paragraph","position":{"start":{"line":233,"column":1},"end":{"line":236,"column":1}},"children":[{"type":"text","value":"Interpretation: Der negative Wert der relativen Rechenzeitänderung zeigt, dass\n","position":{"start":{"line":233,"column":1},"end":{"line":233,"column":1}},"key":"NJGrgBXmVX"},{"type":"inlineCode","value":"downscale=2","position":{"start":{"line":233,"column":1},"end":{"line":233,"column":1}},"key":"TxinWIYolw"},{"type":"text","value":" mehr Rechenzeit benötigt als ","position":{"start":{"line":233,"column":1},"end":{"line":233,"column":1}},"key":"lTMqDxt3lp"},{"type":"inlineCode","value":"downscale=4","position":{"start":{"line":233,"column":1},"end":{"line":233,"column":1}},"key":"CATOd1HEAD"},{"type":"text","value":". Pro Einheit dieses\nMehraufwands gewinnen wir jedoch etwa 7,4-fach mehr Qualität zurück. Das ist\nein sehr gutes Verhältnis.","position":{"start":{"line":233,"column":1},"end":{"line":233,"column":1}},"key":"DOXmjPSFbL"}],"key":"N8O5cKhuvx"},{"type":"paragraph","position":{"start":{"line":238,"column":1},"end":{"line":242,"column":1}},"children":[{"type":"text","value":"Empfehlung: Für einen ersten Qualitätscheck empfiehlt sich ","position":{"start":{"line":238,"column":1},"end":{"line":238,"column":1}},"key":"pV2n1aSYw6"},{"type":"inlineCode