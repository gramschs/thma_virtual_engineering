,\n    position = Vec3(0, 0, 0)\n)\n\n# Kugel\nkugel = Entity(\n    model    = 'sphere',\n    color    = color.red,\n    scale    = 2 * KUGELRADIUS,                     # scale = Durchmesser\n    position = Vec3(START_X, KUGELRADIUS + 0.01, 0)\n)","visibility":"show","key":"FtCu3kmbwD"},{"type":"outputs","id":"hxfCfHWMi7D7-0PDTk4OI","children":[],"visibility":"show","key":"Ok3m9fURBf"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"iqAe9YxJBJ"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Schritt 4: Anzeige und Kamera","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"oFPYRSL4PM"}],"identifier":"schritt-4-anzeige-und-kamera","label":"Schritt 4: Anzeige und Kamera","html_id":"schritt-4-anzeige-und-kamera","implicit":true,"key":"IxnpjbBQcs"}],"key":"lBA9YmIRNH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"anzeige = Text(\n    text     = 't = 0.000 s | v = 0.000 m/s',\n    position = (-0.85, 0.45),\n    scale    = 1.2,\n    color    = color.black\n)\n\nEditorCamera()","visibility":"show","key":"EVct23gNSN"},{"type":"outputs","id":"bzTsORBRMl1WpUtfD5mhe","children":[],"visibility":"show","key":"RdHuTeGYET"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"OinPpXWXAj"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"Schritt 5: Anfangszustand","position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"key":"KLHdYvIsQZ"}],"identifier":"schritt-5-anfangszustand","label":"Schritt 5: Anfangszustand","html_id":"schritt-5-anfangszustand","implicit":true,"key":"jF8Gmt5HL5"}],"key":"XgXdfW5wmL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"geschwindigkeit = 0.0\nt_sim           = 0.0","visibility":"show","key":"QPJ7jYjuz2"},{"type":"outputs","id":"Gn3f65y_zHsvbG6Qf-r4N","children":[],"visibility":"show","key":"Zc5xTtOhVC"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"J6DPdBKqfo"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"Schritt 6: Das vollständige Skript","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"Wuz0UxBO3w"}],"identifier":"schritt-6-das-vollst-ndige-skript","label":"Schritt 6: Das vollständige Skript","html_id":"schritt-6-das-vollst-ndige-skript","implicit":true,"key":"zyXfeunizm"},{"type":"paragraph","position":{"start":{"line":132,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"text","value":"Jetzt fügen wir alle Bausteine zu einem lauffähigen Skript zusammen. Alles\nzusammen in eine Datei, zum Beispiel ","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"lkbobREhUd"},{"type":"inlineCode","value":"kugelbahn.py","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"amysPa7tJN"},{"type":"text","value":":","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"q2Q1HcpC21"}],"key":"O42VgoSIV9"}],"key":"jEnY32hXm3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from ursina import *\nimport math\n\n# --- Anwendung ---\napp = Ursina(title='Kugelbahn: Einfache Rampe')\nwindow.size = Vec2(1200, 700)\nwindow.color = color.white\n\n# --- Parameter ---\nNEIGUNGSWINKEL = 15.0\nBAHNLAENGE     = 1.2\nKUGELRADIUS    = 0.04\nG              = 9.81\nA_X            = G * math.sin(math.radians(NEIGUNGSWINKEL))\nS_EFF          = BAHNLAENGE - 2 * KUGELRADIUS\nSTART_X        = -(BAHNLAENGE / 2) + KUGELRADIUS\nENDE_X         =  (BAHNLAENGE / 2) - KUGELRADIUS\n\n# --- Objekte ---\nEntity(model='cube', color=color.gray,\n       scale=Vec3(BAHNLAENGE, 0.02, 0.12), position=Vec3(0, 0, 0))\n\nkugel = Entity(model='sphere', color=color.red,\n               scale=2*KUGELRADIUS,\n               position=Vec3(START_X, KUGELRADIUS + 0.01, 0))\n\nanzeige = Text(text='', position=(-0.85, 0.45), scale=1.2, color=color.black)\n\nEditorCamera()\n\n# --- Anfangszustand ---\ngeschwindigkeit = 0.0\nt_sim           = 0.0\nlaeuft          = True\n\n# --- Animationsschleife ---\ndef update():\n    global geschwindigkeit, t_sim, laeuft\n\n    if not laeuft:\n        return\n    \n    # Abbruch\n    if kugel.x >= ENDE_X:\n        laeuft = False\n        print(f'Bewegungszeit: {t_sim:.4f} s')\n        print(f'Endgeschwindigkeit: {geschwindigkeit:.4f} m/s')\n\n    # Euler-Cromer-Verfahren: erst Geschwindigkeit, dann Position\n    geschwindigkeit += A_X * time.dt\n    kugel.x         += geschwindigkeit * time.dt\n    t_sim           += time.dt\n\n    # Anzeige\n    anzeige.text = f't = {t_sim:.3f} s | v = {geschwindigkeit:.3f} m/s'\n\napp.run()","visibility":"show","key":"J2IQw6L5o0"},{"type":"outputs","id":"h-UHoAV1ycbg-ArN_v6DF","children":[],"visibility":"show","key":"KBDh94aNAI"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"CoaFSWbs7l"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":196,"column":1},"end":{"line":201,"column":1}},"children":[{"type":"text","value":"Die Reihenfolge “erst Geschwindigkeit, dann Position” ist das\n","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"GdCQIpvakw"},{"type":"strong","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"children":[{"type":"text","value":"Euler-Cromer-Verfahren","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"iEzzKKRDWx"}],"key":"ror0m6GmhH"},{"type":"text","value":" (symplektischer Euler). Es ist energieerhaltender\nals der klassische explizite Euler, bei dem die Position m