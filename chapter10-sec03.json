oloraxis\":{\"colorbar\":{\"outlinewidth\":0,\"ticks\":\"\"}},\"colorscale\":{\"sequential\":[[0,\"#0d0887\"],[0.1111111111111111,\"#46039f\"],[0.2222222222222222,\"#7201a8\"],[0.3333333333333333,\"#9c179e\"],[0.4444444444444444,\"#bd3786\"],[0.5555555555555556,\"#d8576b\"],[0.6666666666666666,\"#ed7953\"],[0.7777777777777778,\"#fb9f3a\"],[0.8888888888888888,\"#fdca26\"],[1,\"#f0f921\"]],\"sequentialminus\":[[0,\"#0d0887\"],[0.1111111111111111,\"#46039f\"],[0.2222222222222222,\"#7201a8\"],[0.3333333333333333,\"#9c179e\"],[0.4444444444444444,\"#bd3786\"],[0.5555555555555556,\"#d8576b\"],[0.6666666666666666,\"#ed7953\"],[0.7777777777777778,\"#fb9f3a\"],[0.8888888888888888,\"#fdca26\"],[1,\"#f0f921\"]],\"diverging\":[[0,\"#8e0152\"],[0.1,\"#c51b7d\"],[0.2,\"#de77ae\"],[0.3,\"#f1b6da\"],[0.4,\"#fde0ef\"],[0.5,\"#f7f7f7\"],[0.6,\"#e6f5d0\"],[0.7,\"#b8e186\"],[0.8,\"#7fbc41\"],[0.9,\"#4d9221\"],[1,\"#276419\"]]},\"xaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\",\"title\":{\"standoff\":15},\"zerolinecolor\":\"white\",\"automargin\":true,\"zerolinewidth\":2},\"yaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\",\"title\":{\"standoff\":15},\"zerolinecolor\":\"white\",\"automargin\":true,\"zerolinewidth\":2},\"scene\":{\"xaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2},\"yaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2},\"zaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2}},\"shapedefaults\":{\"line\":{\"color\":\"#2a3f5f\"}},\"annotationdefaults\":{\"arrowcolor\":\"#2a3f5f\",\"arrowhead\":0,\"arrowwidth\":1},\"geo\":{\"bgcolor\":\"white\",\"landcolor\":\"#E5ECF6\",\"subunitcolor\":\"white\",\"showland\":true,\"showlakes\":true,\"lakecolor\":\"white\"},\"title\":{\"x\":0.05},\"mapbox\":{\"style\":\"light\"}}},\"shapes\":[{\"line\":{\"color\":\"tomato\",\"dash\":\"dash\"},\"type\":\"line\",\"x0\":1.51,\"x1\":1.51,\"xref\":\"x\",\"y0\":0,\"y1\":1,\"yref\":\"y domain\"},{\"line\":{\"color\":\"royalblue\",\"dash\":\"dot\"},\"type\":\"line\",\"x0\":1.6349999999999871,\"x1\":1.6349999999999871,\"xref\":\"x\",\"y0\":0,\"y1\":1,\"yref\":\"y domain\"}],\"annotations\":[{\"showarrow\":false,\"text\":\"Messung: 1.51 s\",\"x\":1.51,\"xanchor\":\"left\",\"xref\":\"x\",\"y\":1,\"yanchor\":\"top\",\"yref\":\"y domain\"},{\"showarrow\":false,\"text\":\"Simulation: 1.635 s\",\"x\":1.6349999999999871,\"xanchor\":\"left\",\"xref\":\"x\",\"y\":1,\"yanchor\":\"top\",\"yref\":\"y domain\"}],\"title\":{\"text\":\"Segmentweise Simulation: Geschwindigkeit über Zeit\"},\"xaxis\":{\"title\":{\"text\":\"Zeit (s)\"}},\"yaxis\":{\"title\":{\"text\":\"Geschwindigkeit (m/s)\"}}},\"config\":{\"plotlyServerURL\":\"https://plot.ly\"}}","content_type":"application/vnd.plotly.v1+json"},"text/html":{"content_type":"text/html","hash":"b12b56e70d5ca7f140335707f5cf49e7","path":"/thma_virtual_engineering/build/b12b56e70d5ca7f140335707f5cf49e7.html"}}},"key":"j70KQynDuu"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Relative Abweichung: +8.28 %\n"},"key":"m4f4DcbP7a"}],"key":"AdTAityFGr"}],"key":"ziAX0Ao7ck"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":233,"column":1},"end":{"line":233,"column":1}},"children":[{"type":"text","value":"Schritt 5: μ_G durch Kalibrierung bestimmen","position":{"start":{"line":233,"column":1},"end":{"line":233,"column":1}},"key":"MeQnEeezJy"}],"identifier":"schritt-5-g-durch-kalibrierung-bestimmen","label":"Schritt 5: μ_G durch Kalibrierung bestimmen","html_id":"schritt-5-g-durch-kalibrierung-bestimmen","implicit":true,"key":"XTUULBDIjC"},{"type":"paragraph","position":{"start":{"line":235,"column":1},"end":{"line":235,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":235,"column":1},"end":{"line":235,"column":1}},"children":[{"type":"text","value":"Warum stimmt die Simulation nicht sofort mit der Messung überein?","position":{"start":{"line":235,"column":1},"end":{"line":235,"column":1}},"key":"HWzAuWPffj"}],"key":"UGxQgir5Uu"}],"key":"qDL1j8AYhP"},{"type":"paragraph","position":{"start":{"line":237,"column":1},"end":{"line":239,"column":1}},"children":[{"type":"text","value":"Der Reibungskoeffizient aus der Literatur ist eine Näherung. Wir können ihn\ndurch Kalibrierung an unserem Messwert verbessern: Wir suchen das μ_G, das\ndie simulierte Bewegungszeit dem Messwert am nächsten bringt.","position":{"start":{"line":237,"column":1},"end":{"line":237,"column":1}},"key":"k6m6niiEaN"}],"key":"UDCnZr4LFK"}],"key":"XnmN3UCxDT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def simuliere(wegpunkte, m, G, MU_H, MU_G, dt=0.005):\n    \"\"\"Simuliert die Bewegungszeit entlang der Bahn.\n\n    Verwendet dasselbe Reibungsmodell wie die segmentweise Schleife:\n    - z ist die Höhenkoordinate,\n    - F_H_along ist die Hangkomponente entlang der Bahn (bergab, ≥ 0),\n    - wenn v ≈ 0 und |F_H_along| ≤ F_Haft,max, kommt die Kugel zum Stillstand.\n    \"\"\"\n    laengen, winkel_rad = bahn_aus_wegpunkten(wegpunkte)\n\n    v = 0.0   # Anfangsgeschwindigkeit\n    t = 0.0   # Gesamtzeit\n\n    for L, theta in zip(laengen, winkel_rad):\n        # Kräfte im aktuellen Segment\n        F_N       = m * G * math.cos(theta)\n        F_H       = m * G * math.sin(theta)   # kann negativ sein (Gefälle)\n        F_H_along = -F_H                      # bergab (≥ 0 bei Gefälle)\n        F_haft    = MU_H * F_N\n        F_gleit   = MU_G * F_N\n\n        # Startbedingung in diesem Segment: Kugel rollt hier nicht mehr los\n        if F_H_along <= F_haft and v <= 1e-6:\n            break\n\n        s_seg = 0.0\n\n        while s_seg < L:\n            # Wenn die Kugel (fast) steht und Haftung ausreicht, endet die Bewegung\n            if v <= 1e-6 and F_H_along <= F_haft:\n                v = 0.0\n                return t\n\n            # Gleitreibung entlang der Bahn\n            a = (F_H_along - F_gleit) / m\n\n            # Euler-Cromer-Schritt\n            v += a * dt\n            if v < 0:\n                v = 0.0\n                return t\n\n            s_step = v * dt\n            s_seg += s_step\n            t     += dt\n\n    return t\n\nT_MESSUNG = 1.51\n\n# Bisektionsverfahren: μ_G auf vier Dezimalstellen genau bestimmen\nmu_lo, mu_hi = 0.05, 0.45\nfor _ in range(40):\n    mu_mid  = (mu_lo + mu_hi) / 2\n    t_mid   = simuliere(wegpunkte, m, G, MU_H, mu_mid)\n    if t_mid < T_MESSUNG:\n        mu_lo = mu_mid   # zu wenig Reibung → Bewegungszeit zu kurz\n    else:\n        mu_hi = mu_mid\n\nmu_mid = (mu_lo + mu_hi) / 2\nt_kalibriert = simuliere(wegpunkte, m, G, MU_H, mu_mid)\nprint(f\"Kalibriertes μ_G:    {mu_mid:.4f}\")\nprint(f\"Simulationszeit:     {t_kalibriert:.5f} s\")\nprint(f\"Messung:             {T_MESSUNG:.5f} s\")\nprint(f\"Restabweichung:      {abs(t_kalibriert - T_MESSUNG) / T_MESSUNG * 100:.4f} %\")","key":"dpvXCLCZcg"},{"type":"outputs","id":"JkcJTHZoLzvuQCpTULy6Q","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Kalibriertes μ_G:    0.4500\nSimulationszeit:     0.00000 s\nMessung:             1.51000 s\nRestabweichung:      100.0000 %\n"},"key":"an4tKNcGp6"}],"key":"iwafunoQtD"}],"key":"TrSlFEcMNM"},{"type":"block","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Mini-Übung","position":{"start":{"line":310,"column":1},"end":{"line":310,"column":1}},"key":"NGsH7rOD5f"}],"key":"Np97ZrVFOW"},{"type":"paragraph","position":{"start":{"line":312,"column":1},"end":{"line":316,"column":1}},"children":[{"type":"text","value":"Verändern Sie ","position":{"start":{"line":312,"column":1},"end":{"line":312,"column":1}},"key":"aLsgUl8j4k"},{"type":"inlineCode","value":"MU_G","position":{"start":{"line":312,"column":1},"end":{"line":312,"column":1}},"key":"NycOylU8vu"},{"type":"text","value":" manuell von 0.10 auf 0.35 in Schritten von 0.05 und\ntragen Sie die simulierte Bewegungszeit in einer Tabelle ein. Vergleichen\nSie diese mit dem kalibrierten Wert aus der Bisektion. Entspricht der\nkalibrierte Wert einem der Schritte, oder liegt er zwischen zwei\nTabellenwerten?","position":{"start":{"line":312,"column":1},"end":{"line":312,"column":1}},"key":"VN9pRANHfu"}],"key":"vcpOgUUvAz"}],"class":"tip","key":"QxDj33aqTR"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Lösung","position":{"start":{"line":319,"column":1},"end":{"line":319,"column":1}},"key":"cg9aKQCj20"}],"key":"gNIblOjGkM"},{"type":"code","lang":"python","value":"import pandas as pd\n\nT_MESSUNG = 1.51\ndaten     = []\n\nfor mu_g in np.arange(0.10, 0.40, 0.05):\n    t = simuliere(wegpunkte, m, G, MU_H, round(mu_g, 2))\n    abw = (t - T_MESSUNG) / T_MESSUNG * 100\n    daten.append({\"μ_G\": round(mu_g, 2),\n                  \"t_sim (s)\": round(t, 4),\n                  \"Δ (%)\": round(abw, 2)})\n\ndf = pd.DataFrame(daten)\nprint(df.to_string(index=False))","position":{"start":{"line":322,"column":1},"end":{"line":337,"column":1}},"key":"Eey6FaiBCX"},{"type":"paragraph","position":{"start":{"line":339,"column":1},"end":{"line":342,"column":1}},"children":[{"type":"text","value":"Der kalibrierte Wert liegt fast immer zwischen zwei Tabelleneinträgen, weil\ndie Schrittweite von 0.05 zu grob ist, um den Messwert exakt zu treffen.\nDie Bisektion bestimmt μ_G auf vier Dezimalstellen, weit feiner als jede\nmanuelle Tabelle.","position":{"start":{"line":339,"column":1},"end":{"line":339,"column":1}},"key":"FsRvZ7hQtr"}],"key":"WZvF8s2Q5k"}],"class":"tip dropdown","key":"qAWhsNVB33"},{"type":"heading","depth":2,"position":{"start":{"line":345,"column":1},"end":{"line":345,"column":1}},"children":[{"type":"text","value":"Zusammenfassung und Ausblick","position":{"start":{"line":345,"column":1},"end":{"line":345,"column":1}},"key":"L6TNHPcBS3"}],"identifier":"zusammenfassung-und-ausblick","label":"Zusammenfassung und Ausblick","html_id":"zusammenfassung-und-ausblick","implicit":true,"key":"L0l5ykfqRO"},{"type":"paragraph","position":{"start":{"line":347,"column":1},"end":{"line":353,"column":1}},"children":[{"type":"text","value":"In diesem Abschnitt haben wir die vollständige segmentweise Simulation\nimplementiert. Die Funktion ","position":{"start":{"line":347,"column":1},"end":{"line":347,"column":1}},"key":"JeMYX5q57E"},{"type":"inlineCode","value":"bahn_aus_wegpunkten","position":{"start":{"line":347,"column":1},"end":{"line":347,"column":1}},"key":"OnFctbgBu7"},{"type":"text","value":" liefert Längen und Winkel\naller Segmente; die doppelte Euler-Cromer-Schleife verarbeitet sie\nnacheinander und gibt die Geschwindigkeit nahtlos von Segment zu Segment\nweiter. Der Vergleich mit dem Messwert zeigt, dass der Reibungskoeffizient\nder wichtigste Stellhebel für die Genauigkeit ist. Das Bisektionsverfahren\nbestimmt ihn auf vier Dezimalstellen in weniger als 40 Iterationen.","position":{"start":{"line":347,"column":1},"end":{"line":347,"column":1}},"key":"VVgoodSedk"}],"key":"HC69nJOWh8"},{"type":"paragraph","position":{"start":{"line":355,"column":1},"end":{"line":357,"column":1}},"children":[{"type":"text","value":"Im nächsten Abschnitt verlassen wir die reine Zahlenebene und bringen die\nSimulation zum Leuchten: Ursina lädt das echte ","position":{"start":{"line":355,"column":1},"end":{"line":355,"column":1}},"key":"rg5CcvYiBm"},{"type":"inlineCode","value":".obj","position":{"start":{"line":355,"column":1},"end":{"line":355,"column":1}},"key":"s6WXWXnX9y"},{"type":"text","value":"-Mesh der Kugelbahn und\nspielt die soeben berechnete Trajektorie als 3D-Animation ab.","position":{"start":{"line":355,"column":1},"end":{"line":355,"column":1}},"key":"PEx6MOaNdT"}],"key":"sVjq6y9miK"}],"key":"d6nwAGnZhG"}],"key":"GOKiZCNesy"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"10.2 Wie validiere ich eine Simulation?","url":"/chapter10-sec02","group":"10. Simulation trifft Realität"},"next":{"title":"10.4 Ursina: Das echte Mesh in Bewegung","url":"/chapter10-sec04","group":"10. Simulation trifft Realität"}}},"domain":"http://localhost:3000"}