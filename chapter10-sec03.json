{"version":3,"kind":"Notebook","sha256":"f3cec844182097d27c0091b48807914b9de00639dd7914c1345f142b24e3fda2","slug":"chapter10-sec03","location":"/chapter10/chapter10_sec03.md","dependencies":[],"frontmatter":{"title":"10.3 Python: Segmentweise Simulation und Validierung","kernelspec":{"name":"python3","display_name":"Python 3"},"content_includes_title":false,"authors":[{"id":"Simone Gramsch","name":"Simone Gramsch"}],"open_access":true,"license":{"content":{"id":"CC-BY-NC-SA-4.0","url":"https://creativecommons.org/licenses/by-nc-sa/4.0/","name":"Creative Commons Attribution Non Commercial Share Alike 4.0 International","CC":true}},"github":"https://github.com/gramschs/thma_virtual_engineering","numbering":{"title":{"offset":1}},"source_url":"https://github.com/gramschs/thma_virtual_engineering/blob/main/chapter10/chapter10_sec03.md","edit_url":"https://github.com/gramschs/thma_virtual_engineering/edit/main/chapter10/chapter10_sec03.md","exports":[{"format":"md","filename":"chapter10_sec03.md","url":"/thma_virtual_engineering/build/chapter10_sec03-699a84a9b7aa9911d90766dd2f120c21.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Wir haben die Wegpunkte der Bahn in Abschnitt 10.1 berechnet und die\nMesswerkzeuge in Abschnitt 10.2 kennengelernt. Jetzt kommen beide Bausteine\nzusammen. Die Euler-Cromer-Schleife aus Kapitel 9 verarbeitet in diesem\nAbschnitt nicht mehr ein einziges gerades Segment, sondern wandert von\nWegpunkt zu Wegpunkt durch die gesamte Bahn. Das Ergebnis ist eine\nZeitreihe von Geschwindigkeit und Position, die wir direkt mit unseren\nMesswerten vergleichen.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"b63LyIYR25"}],"key":"tBz9hPcPP7"},{"type":"heading","depth":2,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Lernziele","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"mhsXvJRFYb"}],"identifier":"lernziele","label":"Lernziele","html_id":"lernziele","implicit":true,"key":"RI802dC9CA"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Lernziele","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"G3I2uwv0Jy"}],"key":"PPAJkOULDA"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":21,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Sie können einen segmentweisen Euler-Cromer-Loop implementieren, der\ndie Geschwindigkeit nahtlos von einem Segment zum nächsten weitergibt.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"CmkgWtLS1l"}],"key":"DnMGz3UIBS"}],"checked":false,"key":"el1XnfFmDB"},{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Sie können die Kräfte pro Segment aus dem lokalen Neigungswinkel\nberechnen und den Haft-/Gleitzustand segmentweise prüfen.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"xJnOVQmg7c"}],"key":"PnA680P9FA"}],"checked":false,"key":"mLVG3InXZW"},{"type":"listItem","spread":true,"position":{"start":{"line":25,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Sie können das Simulationsergebnis mit einem Messwert aus Abschnitt\n10.2 vergleichen und die relative Abweichung berechnen.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"mSVXhbzTWL"}],"key":"BvqO3ixCpR"}],"checked":false,"key":"OFNh1BqEez"},{"type":"listItem","spread":true,"position":{"start":{"line":27,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Sie können den Gleitreibungskoeffizienten durch Kalibrierung an einem\nMesswert bestimmen.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"Njy9Bsbgzu"}],"key":"xFelfskDG9"}],"checked":false,"key":"cGCS9T9hrg"}],"key":"vZVreRasve"}],"class":"attention","key":"dcEDK8KX6r"},{"type":"heading","depth":2,"position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"Schritt 1: Geometrie und Parameter vorbereiten","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"oXArMIJBsJ"}],"identifier":"schritt-1-geometrie-und-parameter-vorbereiten","label":"Schritt 1: Geometrie und Parameter vorbereiten","html_id":"schritt-1-geometrie-und-parameter-vorbereiten","implicit":true,"key":"eBPIQlCKDf"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Wir beginnen mit der Funktion ","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"eT9G2s7K0J"},{"type":"inlineCode","value":"bahn_aus_wegpunkten","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"RFUufjIJh1"},{"type":"text","value":" aus Abschnitt 10.1 und\nden Physikparametern aus Kapitel 9. Alle Parameter stehen am Anfang des\nSkripts als Konstanten:","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"AM4agvJcTT"}],"key":"o9mZieWoJZ"}],"key":"CVVnFx3k7Q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport math\n\ndef bahn_aus_wegpunkten(wegpunkte):\n    \"\"\"Berechnet Segmentlängen und lokale Neigungswinkel.\n\n    Annahme: Wegpunkte als (x, y, z) in m, z ist die Höhenkoordinate.\n    \"\"\"\n    laengen, winkel_rad = [], []\n    for i in range(len(wegpunkte) - 1):\n        delta  = wegpunkte[i+1] - wegpunkte[i]\n        laenge = np.linalg.norm(delta)\n        # horizontale Distanz in der x-y-Ebene\n        delta_horiz = np.sqrt(delta[0]**2 + delta[1]**2)\n        # Neigung: z als Höhe\n        theta = np.arctan2(delta[2], delta_horiz)\n        laengen.append(laenge)\n        winkel_rad.append(theta)\n    return np.array(laengen), np.array(winkel_rad)\n\n# Wegpunkte (aus CloudCompare exportiert oder manuell definiert)\n# x: Bahnlänge, y: seitliche Lage, z: Höhe (negativ bergab)\nwegpunkte = np.array([\n    [0.00, 0.000,  0.000],\n    [0.12, 0.010, -0.030],  # steil\n    [0.25, 0.020, -0.050],  # flacher\n    [0.38, 0.025, -0.065],\n    [0.51, 0.030, -0.075],\n    [0.63, 0.025, -0.090],\n    [0.76, 0.015, -0.105],\n    [0.88, 0.005, -0.115],\n    [1.00, 0.000, -0.120],\n])\n\nlaengen, winkel_rad = bahn_aus_wegpunkten(wegpunkte)\n\n# Physikparameter\nm    = 0.1      # Masse in kg\nG    = 9.81     # Erdbeschleunigung in m/s²\nMU_H = 0.20     # Haftreibungskoeffizient\nMU_G = 0.15     # Gleitreibungskoeffizient\ndt = 0.005 # Zeitschritt in s\n\nprint(f\"Segmente:      {len(laengen)}\")\nprint(f\"Gesamtlänge:   {np.sum(laengen):.4f} m\")\nprint(f\"Winkelbereich: {np.degrees(winkel_rad.min()):.1f}° \"\n      f\"bis {np.degrees(winkel_rad.max()):.1f}°\")","key":"IPmntgo5Hf"},{"type":"outputs","id":"OJBxSoVpX0dVo6RXt-Ou6","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Segmente:      8\nGesamtlänge:   1.0108 m\nWinkelbereich: -14.0° bis -2.4°\n"},"key":"yAU6SnQY7d"}],"key":"EnLfEtPcs4"}],"key":"FOYfX0DyWj"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":87,"column":1},"end":{"line":87,"column":1}},"children":[{"type":"text","value":"Schritt 2: Kräfte pro Segment berechnen","position":{"start":{"line":87,"column":1},"end":{"line":87,"column":1}},"key":"lWHuzrG2wc"}],"identifier":"schritt-2-kr-fte-pro-segment-berechnen","label":"Schritt 2: Kräfte pro Segment berechnen","html_id":"schritt-2-kr-fte-pro-segment-berechnen","implicit":true,"key":"aTQm5LosAt"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Für jedes Segment berechnen wir Normalkraft, Hangabtrieb, Haftgrenze und\nGleitreibung einmalig. Diese Werte sind innerhalb eines Segments konstant\nund hängen nur vom lokalen Neigungswinkel ab:","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"lvmqge560m"}],"key":"NpUXHP1DQp"}],"key":"pKHkhqmlhI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"F_N_seg        = m * G * np.cos(winkel_rad)\nF_H_seg        = m * G * np.sin(winkel_rad)\nF_HAFT_MAX_seg = MU_H * F_N_seg\nF_GLEIT_seg    = MU_G  * F_N_seg\n\nprint(f\"{'Seg':>4} {'θ (°)':>7} {'F_H (N)':>9} \"\n      f\"{'F_Haft,max (N)':>15} {'gleitet?':>10}\")\nfor i in range(len(laengen)):\n    gleitet = abs(F_H_seg[i]) > F_HAFT_MAX_seg[i]\n    print(f\"{i+1:>4} {np.degrees(winkel_rad[i]):>7.2f} \"\n          f\"{F_H_seg[i]:>9.4f} {F_HAFT_MAX_seg[i]:>15.4f} \"\n          f\"{'ja' if gleitet else 'nein':>10}\")","key":"tqu9iD0Dad"},{"type":"outputs","id":"6UwTaUvauoJWMcEc6RTgx","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":" Seg   θ (°)   F_H (N)  F_Haft,max (N)   gleitet?\n   1  -13.99   -0.2372          0.1904         ja\n   2   -8.72   -0.1487          0.1939       nein\n   3   -6.58   -0.1124          0.1949       nein\n   4   -4.40   -0.0752          0.1956       nein\n   5   -7.12   -0.1216          0.1947       nein\n   6   -6.56   -0.1121          0.1949       nein\n   7   -4.75   -0.0812          0.1955       nein\n   8   -2.38   -0.0408          0.1960       nein\n"},"key":"v16gO0RpXn"}],"key":"GFze637Fgb"}],"key":"zQoyPJkr3M"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":108,"column":1},"end":{"line":109,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Was passiert, wenn ein Segment so flach ist, dass die Kugel dort nicht\ngleitet?","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"f5umG40p8v"}],"key":"GzGtpPZ4Vz"}],"key":"AmiHGLQ0ch"},{"type":"paragraph","position":{"start":{"line":111,"column":1},"end":{"line":116,"column":1}},"children":[{"type":"text","value":"Wenn ","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"Uo47UkESHi"},{"type":"inlineCode","value":"|F_H| ≤ F_Haft,max","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"wsoXpH1zh5"},{"type":"text","value":", bremst die Haftreibung die Kugel bis zum\nStillstand, aber nur, wenn sie auch langsam genug ist. Eine Kugel, die\nbereits mit hoher Geschwindigkeit in ein flaches Segment eintritt, wird durch\ndie Gleitreibung abgebremst, kommt aber möglicherweise erst im nächsten\nSegment zum Stillstand. Die segmentweise Schleife behandelt diesen Fall durch\ndie Geschwindigkeitsweitergabe zwischen Segmenten.","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"T14tccLewy"}],"key":"BPsuj7VlmO"},{"type":"heading","depth":2,"position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"children":[{"type":"text","value":"Schritt 3: Die segmentweise Schleife","position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"key":"pPy3zphv4J"}],"identifier":"schritt-3-die-segmentweise-schleife","label":"Schritt 3: Die segmentweise Schleife","html_id":"schritt-3-die-segmentweise-schleife","implicit":true,"key":"Lha1Rdyb4o"},{"type":"paragraph","position":{"start":{"line":120,"column":1},"end":{"line":123,"column":1}},"children":[{"type":"text","value":"Das Kernstück der Simulation ist eine doppelte Schleife: Die äußere Schleife\niteriert über alle Segmente, die innere führt die Euler-Cromer-Schritte\ninnerhalb eines Segments durch. Die Geschwindigkeit wird nahtlos von einem\nSegment zum nächsten weitergegeben:","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"EmWTkiGctn"}],"key":"AFobt3PvSi"}],"key":"EOohnZJzvI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Anfangszustand\nv_aktuell = 0.0   # m/s (optional: kleiner Startstoß, z.B. 0.05)\nt_gesamt  = 0.0\ns_gesamt  = 0.0\n\nt_verlauf = [0.0]\nv_verlauf = [v_aktuell]\ns_verlauf = [0.0]\n\nstopped = False\n\n# Äußere Schleife: über alle Segmente\nfor seg_idx, (L, theta) in enumerate(zip(laengen, winkel_rad), start=1):\n    # Kräfte im aktuellen Segment\n    F_N       = m * G * math.cos(theta)\n    F_H       = m * G * math.sin(theta)   # kann negativ sein (Gefälle)\n    F_H_along = -F_H                      # Betrag in Richtung \"bergab\" (>= 0)\n    F_haft    = MU_H * F_N\n    F_gleit   = MU_G * F_N\n\n    # Prüfen, ob die Kugel in diesem Segment überhaupt losrollen kann\n    if F_H_along <= F_haft and v_aktuell <= 1e-6:\n        print(f\"Kugel bleibt in Segment {seg_idx} stehen \"\n              f\"(|F_H| <= F_Haft,max und v ≈ 0).\")\n        stopped = True\n        break\n\n    s_seg = 0.0  # zurückgelegte Distanz im aktuellen Segment\n\n    # Innere Schleife: Euler-Cromer-Schritte im Segment\n    while s_seg < L:\n        # Wenn die Kugel (fast) steht und Haftung ausreicht, endet die Bewegung\n        if v_aktuell <= 1e-6 and F_H_along <= F_haft:\n            v_aktuell = 0.0\n            stopped = True\n            break\n\n        # Gleitreibung entlang der Bahn (nur Bewegung bergab betrachtet)\n        a = (F_H_along - F_gleit) / m\n\n        # Euler-Cromer: erst Geschwindigkeit, dann Weg und Zeit\n        v_aktuell += a * dt\n        if v_aktuell < 0:\n            v_aktuell = 0.0\n\n        s_step   = v_aktuell * dt\n        s_seg   += s_step\n        s_gesamt += s_step\n        t_gesamt += dt\n\n        t_verlauf.append(t_gesamt)\n        v_verlauf.append(v_aktuell)\n        s_verlauf.append(s_gesamt)\n\n    if stopped:\n        break\n\nprint(f\"Bewegungszeit:      {t_gesamt:.4f} s\")\nprint(f\"Endgeschwindigkeit: {v_aktuell:.4f} m/s\")\nprint(f\"Gesamtstrecke:      {s_gesamt:.4f} m\")","key":"x0keSyurS9"},{"type":"outputs","id":"yVP4KdrzlXAOzKy-SRmu9","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Bewegungszeit:      1.6350 s\nEndgeschwindigkeit: 0.0000 m/s\nGesamtstrecke:      0.4980 m\n"},"key":"nCALhrEG8t"}],"key":"QaPAQ9XN3I"}],"key":"sjL1CdNAiS"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":188,"column":1},"end":{"line":194,"column":1}},"children":[{"type":"text","value":"Der Zustandscheck findet beim Eintritt in jedes Segment und innerhalb der\ninneren Schleife statt: Wenn die Hangabtriebskraft nicht ausreicht, um die\nHaftreibung zu überwinden und die Kugel (fast) steht, beenden wir die\nSimulation. Die Geschwindigkeit ","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"aU5Bs63t9y"},{"type":"inlineCode","value":"v_aktuell","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"lXLPrpjAQx"},{"type":"text","value":" wird in jedem Zeitschritt\naktualisiert und am Segmentende nahtlos an das nächste Segment weitergegeben.\nDie Euler-Cromer-Reihenfolge (zuerst Geschwindigkeit, dann Weg) stellt sicher,\ndass die Energieentwicklung physikalisch sinnvoll bleibt.","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"sGY2nnMKTt"}],"key":"ZBDiMLH4iU"},{"type":"heading","depth":2,"position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"children":[{"type":"text","value":"Schritt 4: Ergebnis mit Messung vergleichen","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"Opx2oFeSYv"}],"identifier":"schritt-4-ergebnis-mit-messung-vergleichen","label":"Schritt 4: Ergebnis mit Messung vergleichen","html_id":"schritt-4-ergebnis-mit-messung-vergleichen","implicit":true,"key":"S9jbtI0luN"},{"type":"paragraph","position":{"start":{"line":198,"column":1},"end":{"line":199,"column":1}},"children":[{"type":"text","value":"Wir stellen die simulierte Geschwindigkeit als Funktion der Zeit dar und\nmarkieren den Messwert aus Abschnitt 10.2 als vertikale Linie:","position":{"start":{"line":198,"column":1},"end":{"line":198,"column":1}},"key":"Y9cnZIda8F"}],"key":"t94ppT98ID"}],"key":"dC3Q8HnG8M"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import plotly.graph_objects as go\n\nT_MESSUNG = 1.51   # s aus Stoppuhr (Abschnitt 10.2)\n\nfig = go.Figure()\n\nfig.add_trace(go.Scatter(\n    x=t_verlauf, y=v_verlauf,\n    mode='lines', name='Simulation',\n    line=dict(color='royalblue', width=2)\n))\nfig.add_vline(\n    x=T_MESSUNG, line_dash='dash', line_color='tomato',\n    annotation_text=f'Messung: {T_MESSUNG} s'\n)\nfig.add_vline(\n    x=t_gesamt, line_dash='dot', line_color='royalblue',\n    annotation_text=f'Simulation: {t_gesamt:.3f} s'\n)\n\nfig.update_layout(\n    title='Segmentweise Simulation: Geschwindigkeit über Zeit',\n    xaxis_title='Zeit (s)',\n    yaxis_title='Geschwindigkeit (m/s)'\n)\nfig.show()\n\ndelta_rel = (t_gesamt - T_MESSUNG) / T_MESSUNG * 100\nprint(f\"Relative Abweichung: {delta_rel:+.2f} %\")","key":"npR7gByrXu"},{"type":"outputs","id":"CaIrHxiJGPYAYFD8UkhMq","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/html":{"content_type":"text/html","hash":"894c0f0bc0c224617506b58673feec22","path":"/thma_virtual_engineering/build/894c0f0bc0c224617506b58673feec22.html"}}},"key":"ACXJjBVCFq"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.plotly.v1+json":{"content":"{\"data\":[{\"line\":{\"color\":\"royalblue\",