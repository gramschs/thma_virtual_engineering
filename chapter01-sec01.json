npD6P4K"},{"type":"code","lang":"code","value":"Idee → Skizze → physischer Prototyp → Test → Korrektur → Serienproduktion","position":{"start":{"line":116,"column":1},"end":{"line":118,"column":1}},"key":"LFNkQv1dxy"},{"type":"paragraph","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"children":[{"type":"text","value":"Im Digital-First-Ansatz sieht der Ablauf anders aus:","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"BovQzJa9o3"}],"key":"u0bjjsYuK5"},{"type":"code","lang":"code","value":"Idee → digitales Modell → Simulation → Optimierung → (physischer Prototyp) → Serienproduktion","position":{"start":{"line":122,"column":1},"end":{"line":124,"column":1}},"key":"ya1pE6geWn"},{"type":"paragraph","position":{"start":{"line":126,"column":1},"end":{"line":128,"column":1}},"children":[{"type":"text","value":"Der physische Prototyp wird damit seltener und später gebaut. In manchen Fällen\nentfällt er ganz. Das spart Zeit, Material und Kosten und ermöglicht eine\nnachhaltigere Produktentwicklung.","position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"key":"bxiDk5hyze"}],"key":"bmTqjnteeE"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Mini-Übung","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"Pip7cvFAbm"}],"key":"TB1X4wa97W"},{"type":"paragraph","position":{"start":{"line":132,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"text","value":"Recherchieren Sie ein konkretes Industriebeispiel, in dem ein Unternehmen einen\nDigitalen Zwilling einsetzt. Beschreiben Sie in drei bis vier Sätzen:","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"ExO97HrZTE"}],"key":"apstwiyRAj"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":135,"column":1},"end":{"line":137,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Was ist das physische Objekt?","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"HfwlVsVqVV"}],"key":"OZzQJEsfqf"}],"key":"a6sK1KJtDz"},{"type":"listItem","spread":true,"position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Was enthält das digitale Modell?","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"key":"dV7PaWkZUp"}],"key":"yVESGuF0E8"}],"key":"DACeDCdNmd"},{"type":"listItem","spread":true,"position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Welchen Nutzen bringt der Digitale Zwilling in diesem Fall?","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"key":"lxqOYS6jeJ"}],"key":"A76JmQMj8I"}],"key":"A8qn7M5rTx"}],"key":"hUKXQ5ozpb"}],"class":"tip","key":"mgRHcv9NbE"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Lösung","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"AwADo4JGYR"}],"key":"Ymlxx8HhP6"},{"type":"paragraph","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"children":[{"type":"text","value":"Beispiel: ","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"key":"Jsbx262LZ4"},{"type":"strong","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"children":[{"type":"text","value":"Siemens und die digitale Gasturbine","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"key":"Rze7qmA3oM"}],"key":"IJuVXv1Fti"}],"key":"n22xu7KOal"},{"type":"paragraph","position":{"start":{"line":145,"column":1},"end":{"line":152,"column":1}},"children":[{"type":"text","value":"Das physische Objekt ist eine Gasturbine, die in einem Kraftwerk Strom erzeugt.\nDas digitale Modell enthält die vollständige Geometrie der Turbine, ihre\nMaterialeigenschaften und ein thermodynamisches Simulationsmodell, das das\nVerhalten unter verschiedenen Betriebsbedingungen vorhersagt. Die Datenverbindung\nwird über Sensoren hergestellt, die kontinuierlich Temperatur, Druck und\nSchwingungen messen und an das digitale Modell übermitteln. Der Nutzen besteht\ndarin, dass Wartungsintervalle vorausschauend geplant werden können und\nungeplante Ausfälle vermieden werden, was die Betriebskosten erheblich senkt.","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"iQz5ogfOpR"}],"key":"RGG5UOcNDx"},{"type":"paragraph","position":{"start":{"line":154,"column":1},"end":{"line":155,"column":1}},"children":[{"type":"text","value":"Andere Beispiele sind ebenfalls korrekt, z. B. BMW (Fahrzeugentwicklung),\nAirbus (Flugzeugwartung) oder Schindler (Aufzugsüberwachung).","position":{"start":{"line":154,"column":1},"end":{"line":154,"column":1}},"key":"SOaY9k2Zy5"}],"key":"qQiD0TgcTr"}],"class":"tip dropdown","key":"rnMmAzSg3l"},{"type":"heading","depth":2,"position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"children":[{"type":"text","value":"Anwendungsfelder im Maschinenbau","position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"key":"G8EgClfjGI"}],"identifier":"anwendungsfelder-im-maschinenbau","label":"Anwendungsfelder im Maschinenbau","html_id":"anwendungsfelder-im-maschinenbau","implicit":true,"key":"iTOPyDb8q2"},{"type":"paragraph","position":{"start":{"line":160,"column":1},"end":{"line":161,"column":1}},"children":[{"type":"text","value":"Virtual Engineering ist heute in nahezu allen Bereichen des Maschinenbaus\npräsent. Die folgende Übersicht zeigt exemplarische Anwendungsfelder:","position":{"start":{"line":160,"column":1},"end":{"line":160,"column":1}},"key":"lgX932m2Cg"}],"key":"u5WUBxT4zd"},{"type":"paragraph","position":{"start":{"line":163,"column":1},"end":{"line":166,"column":1}},"children":[{"type":"strong","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"children":[{"type":"text","value":"Produktentwicklung und Konstruktion","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"key":"xwvD10aIkN"}],"key":"ed1pRtDknX"},{"type":"text","value":"\nVirtuelle Prototypen ermöglichen es, Entwürfe frühzeitig auf Festigkeit,\nSchwingungsverhalten oder Strömungseigenschaften zu prüfen. Topologieoptimierung\nhilft, Bauteile leichter und gleichzeitig stabiler zu gestalten.","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"key":"N5MgjGDeKB"}],"key":"wl9ZE9QiVb"},{"type":"paragraph","position":{"start":{"line":168,"column":1},"end":{"line":171,"column":1}},"children":[{"type":"strong","position":{"start":{"line":168,"column":1},"end":{"line":168,"column":1}},"children":[{"type":"text","value":"Fertigung und Produktion","position":{"start":{"line":168,"column":1},"end":{"line":168,"column":1}},"key":"OrwEiwMjUq"}],"key":"sKPtTrAEwl"},{"type":"text","value":"\nDigitale Zwillinge von Produktionsanlagen erlauben die Simulation ganzer\nFertigungslinien, bevor diese physisch aufgebaut werden. Engpässe und\nFehlerquellen lassen sich so frühzeitig erkennen und beheben.","position":{"start":{"line":168,"column":1},"end":{"line":168,"column":1}},"key":"XPjszJ0j3Y"}],"key":"CdJRUeemhk"},{"type":"paragraph","position":{"start":{"line":173,"column":1},"end":{"line":176,"column":1}},"children":[{"type":"strong","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"children":[{"type":"text","value":"Qualitätssicherung und Reverse Engineering","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"BFLC6JM2H8"}],"key":"kjrKrjKlGa"},{"type":"text","value":"\nDurch den Vergleich gescannter Bauteile mit ihren CAD-Referenzmodellen können\nFertigungsabweichungen exakt quantifiziert werden. Reverse Engineering erlaubt\nes, auch von Bauteilen ohne vorhandene CAD-Daten ein digitales Modell zu erstellen.","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"OgT71gVSBa"}],"key":"LpWMb7830X"},{"type":"paragraph","position":{"start":{"line":178,"column":1},"end":{"line":181,"column":1}},"children":[{"type":"strong","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"text","value":"Wartung und Betrieb","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"Ox9ng3mhAv"}],"key":"XcZsLiZa5w"},{"type":"text","value":"\nIm Betrieb können Digitale Zwillinge genutzt werden, um den Zustand einer Anlage\nkontinuierlich zu überwachen, Ausfälle vorherzusagen (","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"msQYzJr9Op"},{"type":"emphasis","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"text","value":"Predictive Maintenance","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"RGAqIPU4sL"}],"key":"VVegd5EWrq"},{"type":"text","value":")\nund Wartungsintervalle zu optimieren.","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"FFQltHGz4K"}],"key":"xM7mdgNEL4"},{"type":"paragraph","position":{"start":{"line":183,"column":1},"end":{"line":185,"column":1}},"children":[{"type":"strong","position":{"start":{"line":183,"column":1},"end":{"line":183,"column":1}},"children":[{"type":"text","value":"Ausbildung und Training","position":{"start":{"line":183,"column":1},"end":{"line":183,"column":1}},"key":"FPCch7yuZo"}],"key":"IY6CeDprxz"},{"type":"text","value":"\nVirtuelle Umgebungen ermöglichen gefahrenfreies Training an komplexen Anlagen,\nohne dass reale Maschinen belastet werden.","position":{"start":{"line":183,"column":1},"end":{"line":183,"column":1}},"key":"hOg7DF22r3"}],"key":"iOacQL2xsv"},{"type":"heading","depth":2,"position":{"start":{"line":187,"column":1},"end":{"line":187,"column":1}},"children":[{"type":"text","value":"Zusammenfassung und Ausblick","position":{"start":{"line":187,"column":1},"end":{"line":187,"column":1}},"key":"MqOjfSyQeu"}],"identifier":"zusammenfassung-und-ausblick","label":"Zusammenfassung und Ausblick","html_id":"zusammenfassung-und-ausblick","implicit":true,"key":"k7QkT55E3A"},{"type":"paragraph","position":{"start":{"line":189,"column":1},"end":{"line":197,"column":1}},"children":[{"type":"text","value":"In diesem Kapitel haben wir die grundlegenden Konzepte des Virtual Engineering\nkennengelernt. Virtual Engineering umfasst alle digitalen Methoden, die in der\nProduktentwicklung eingesetzt werden. Der Digitale Zwilling als Kernkonzept\nverbindet das physische Objekt mit seinem digitalen Abbild über eine\nbidirektionale Datenverbindung. Der Digital-First-Ansatz stellt das digitale\nModell an den Anfang des Produktlebenszyklus und ermöglicht so eine effizientere\nund nachhaltigere Entwicklung. Im nächsten Abschnitt lernen Sie das Leitprojekt\ndieser Vorlesung kennen: die Digitalisierung, den 3D-Druck und die Simulation\neiner Kugelbahn.","position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"key":"VeDTk9Mg7t"}],"key":"uY3rqlQlaC"}],"key":"jiGsELJMto"}],"key":"zSL26X7VIt"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Inhaltsverzeichnis","url":"/toc","group":"Virtual Engineering"},"next":{"title":"1.2 Das Leitprojekt: Kugelbahn","url":"/chapter01-sec02","group":"1. Was ist Virtual Engineering?"}}},"domain":"http://localhost:3000"}