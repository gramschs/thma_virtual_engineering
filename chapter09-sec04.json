:"d","position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"key":"pgtIrmGkui"},{"type":"text","value":" verringert ","position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"key":"HtiikRdxVg"},{"type":"inlineCode","value":"NEIGUNGSWINKEL","position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"key":"F2RRKLORyZ"},{"type":"text","value":" um 1° (Minimum: 1°).","position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"key":"lAju8aar5s"}],"key":"CSXsfkQGsP"}],"key":"toOST2rpP2"},{"type":"listItem","spread":true,"position":{"start":{"line":173,"column":1},"end":{"line":175,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Nach jeder Änderung soll die Kugel in ihre Startposition zurückgesetzt\nund die Simulation neu gestartet werden.","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"TDSUbN1Mlm"}],"key":"IEGpFQVWkL"}],"key":"Eye9NKuGhI"}],"key":"DcgJkktnnC"},{"type":"paragraph","position":{"start":{"line":176,"column":1},"end":{"line":177,"column":1}},"children":[{"type":"text","value":"Hinweis: Tastatureingaben in Ursina werden über die eingebaute Funktion\n","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"O9s34CSOh6"},{"type":"inlineCode","value":"input(key)","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"Y9nhi6j52W"},{"type":"text","value":" abgefangen:","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"s0A1QCUtOh"}],"key":"dqwFm37MY7"},{"type":"code","lang":"python","value":"def input(key):\n    if key == 'u':\n        # Winkel erhöhen und zurücksetzen\n        ...","position":{"start":{"line":179,"column":1},"end":{"line":184,"column":1}},"key":"flhb5iTVg3"}],"class":"tip","key":"wakHckJVNq"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Lösung","position":{"start":{"line":187,"column":1},"end":{"line":187,"column":1}},"key":"OdNK8cnkxf"}],"key":"fwRRc0Kduq"},{"type":"code","lang":"python","value":"from ursina import *\nimport math\n\napp = Ursina(title='Kugelbahn: Dynamischer Winkel', width=1200, height=700)\nwindow.color = color.white\n\nBAHNLAENGE  = 1.0\nKUGELRADIUS = 0.04\nm, G        = 0.1, 9.81\nMU_H, MU_G  = 0.35, 0.25\n\nneigungswinkel = [20.0]   # als Liste, damit input() darauf zugreifen kann\n\ndef berechne_kraefte(winkel):\n    theta      = math.radians(winkel)\n    F_N        = m * G * math.cos(theta)\n    F_H        = m * G * math.sin(theta)\n    F_HAFT_MAX = MU_H * F_N\n    F_GLEIT    = MU_G * F_N\n    return F_N, F_H, F_HAFT_MAX, F_GLEIT\n\nSTART_X = -(BAHNLAENGE / 2) + KUGELRADIUS\nENDE_X  =  (BAHNLAENGE / 2) - KUGELRADIUS\n\nEntity(model='cube', color=color.gray,\n       scale=Vec3(BAHNLAENGE, 0.02, 0.12))\n\nkugel  = Entity(model='sphere', color=color.red,\n                scale=2*KUGELRADIUS,\n                position=Vec3(START_X, KUGELRADIUS + 0.01, 0))\nstatus = Text(text='', position=(-0.85, 0.45), scale=1.2, color=color.black)\nwinkel_text = Text(text=f'θ = {neigungswinkel[0]:.0f}°  (u/d zum Ändern)',\n                   position=(-0.85, 0.40), scale=1.2, color=color.black)\nEditorCamera()\n\ngeschwindigkeit = [0.0]\nt_sim           = [0.0]\ngleitet         = [False]\nlaeuft          = [True]\n\nF_N, F_H, F_HAFT_MAX, F_GLEIT = berechne_kraefte(neigungswinkel[0])\n\ndef reset():\n    kugel.x            = START_X\n    geschwindigkeit[0] = 0.0\n    t_sim[0]           = 0.0\n    laeuft[0]          = True\n    gleitet[0]         = F_H > F_HAFT_MAX\n    kugel.color        = color.orange if gleitet[0] else color.red\n\nreset()\n\ndef update():\n    global F_N, F_H, F_HAFT_MAX, F_GLEIT\n    if not laeuft[0]:\n        return\n    if not gleitet[0] and F_H > F_HAFT_MAX:\n        gleitet[0]  = True\n        kugel.color = color.orange\n    a                   = (F_H - F_GLEIT) / m if gleitet[0] else 0.0\n    geschwindigkeit[0] += a * time.dt\n    kugel.x            += geschwindigkeit[0] * time.dt\n    t_sim[0]           += time.dt\n    status.text = (f\"θ = {neigungswinkel[0]:.0f}°\\n\"\n                   f\"t = {t_sim[0]:.3f} s\\n\"\n                   f\"v = {geschwindigkeit[0]:.3f} m/s\")\n    if kugel.x >= ENDE_X:\n        laeuft[0] = False\n\ndef input(key):\n    global F_N, F_H, F_HAFT_MAX, F_GLEIT\n    if key == 'u':\n        neigungswinkel[0] += 1.0\n    elif key == 'd':\n        neigungswinkel[0] = max(1.0, neigungswinkel[0] - 1.0)\n    else:\n        return\n    winkel_text.text              = f'θ = {neigungswinkel[0]:.0f}°  (u/d)'\n    F_N, F_H, F_HAFT_MAX, F_GLEIT = berechne_kraefte(neigungswinkel[0])\n    reset()\n\napp.run()","position":{"start":{"line":190,"column":1},"end":{"line":273,"column":1}},"key":"q79d2px8bQ"}],"class":"tip dropdown","key":"B4rh8zm2Ts"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Übung 9.5 (✩✩✩)","position":{"start":{"line":276,"column":1},"end":{"line":276,"column":1}},"key":"Noik7xgzQw"}],"key":"RDMlOU4yUb"},{"type":"paragraph","position":{"start":{"line":278,"column":1},"end":{"line":278,"column":1}},"children":[{"type":"strong","position":{"start":{"line":278,"column":1},"end":{"line":278,"column":1}},"children":[{"type":"text","value":"Einfluss von μ_G auf Bewegungszeit und Endgeschwindigkeit","position":{"start":{"line":278,"column":1},"end":{"line":278,"column":1}},"key":"Hs2d3rdRvo"}],"key":"hlZrRcOKNz"}],"key":"IFmnewICmT"},{"type":"paragraph","position":{"start":{"line":280,"column":1},"end":{"line":282,"column":1}},"children":[{"type":"text","value":"In der Simulation verwenden wir oft Literaturwerte für den\nGleitreibungskoeffizienten. Aber wie empfindlich reagiert die Simulation\nauf diesen Wert?","position":{"start":{"line":280,"column":1},"end":{"line":280,"column":1}},"key":"kgsaumikZh"}],"key":"oJdr8QQ6Qd"},{"type":"paragraph","position":{"start":{"line":284,"column":1},"end":{"line":286,"column":1}},"children":[{"type":"text","value":"Simulieren Sie die Kugel aus Abschnitt 9.3 (θ = 20°, m = 0.1 kg,\nBAHNLAENGE = 1.0 m, μ_H = 0.35) für folgende μ_G-Werte in reinem Python\n(ohne Ursina): 0.05, 0.10, 0.15, 0.20, 0.25, 0.30, 0.35.","position":{"start":{"line":284,"column":1},"end":{"line":284,"column":1}},"key":"h23xrrSr6q"}],"key":"x1FA4blgtN"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":288,"column":1},"end":{"line":294,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":288,"column":1},"end":{"line":289,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Berechnen Sie für jeden Wert die Bewegungszeit und Endgeschwindigkeit\nmit der Euler-Cromer-Schleife (","position":{"start":{"line":288,"column":1},"end":{"line":288,"column":1}},"key":"uL0kX9oejQ"},{"type":"inlineCode","value":"dt = 0.005 s","position":{"start":{"line":288,"column":1},"end":{"line":288,"column":1}},"key":"SLzaMraW6l"},{"type":"text","value":").","position":{"start":{"line":288,"column":1},"end":{"line":288,"column":1}},"key":"OOsDjIvP1v"}],"key":"XD7n6Tm6gj"}],"key":"aKuZ3oZTkc"},{"type":"listItem","spread":true,"position":{"start":{"line":290,"column":1},"end":{"line":290,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Berechnen Sie zusätzlich die analytischen Werte zum Vergleich.","position":{"start":{"line":290,"column":1},"end":{"line":290,"column":1}},"key":"F3ZrXdy02A"}],"key":"UvvTsOOIsE"}],"key":"dRZmfmMCjv"},{"type":"listItem","spread":true,"position":{"start":{"line":291,"column":1},"end":{"line":292,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Stellen Sie beide Ergebnisse (Simulation und Analytik) in einem\neinzigen Plotly-Diagramm dar: Bewegungszeit als Funktion von μ_G.","position":{"start":{"line":291,"column":1},"end":{"line":291,"column":1}},"key":"JABuLHmxRK"}],"key":"NECP4w1akt"}],"key":"dKCopmpstM"},{"type":"listItem","spread":true,"position":{"start":{"line":293,"column":1},"end":{"line":294,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Beantworten Sie: Um wie viel Prozent ändert sich die Bewegungszeit,\nwenn μ_G um 0.05 steigt? Ist die Abhängigkeit linear?","position":{"start":{"line":293,"column":1},"end":{"line":293,"column":1}},"key":"yiJmO9UOo9"}],"key":"CP9IAsvlH3"}],"key":"DWESj1OZzj"}],"key":"lan0KRK4Ew"}],"class":"tip","key":"UC0pCO29Cp"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Lösung","position":{"start":{"line":297,"column":1},"end":{"line":297,"column":1}},"key":"Ey2W8CCaLV"}],"key":"fiwFkvAtiT"},{"type":"code","lang":"python","value":"import math\nimport pandas as pd\nimport plotly.graph_objects as go\n\nG           = 9.81\nTHETA       = math.radians(20)\nm           = 0.1\nMU_H        = 0.35\nBAHNLAENGE  = 1.0\nKUGELRADIUS = 0.04\nS_EFF       = BAHNLAENGE - 2 * KUGELRADIUS\ndt          = 0.005\n\nMU_G_WERTE = [0.05, 0.10, 0.15, 0.20, 0.25, 0.30, 0.35]\nt_sim_liste = []\nt_ana_liste = []\n\nfor MU_G in MU_G_WERTE:\n    F_N     = m * G * math.cos(THETA)\n    F_H     = m * G * math.sin(THETA)\n    F_GLEIT = MU_G * F_N\n\n    # Simulation\n    v, x, t = 0.0, 0.0, 0.0\n    while x < S_EFF:\n        a  = (F_H - F_GLEIT) / m\n        v += a * dt\n        x += v * dt\n        t += dt\n    t_sim_liste.append(t)\n\n    # Analytik\n    a_ana = G * (math.sin(THETA) - MU_G * math.cos(THETA))\n    t_ana = math.sqrt(2 * S_EFF / a_ana)\n    t_ana_liste.append(t_ana)\n\n    print(f\"μ_G = {MU_G:.2f}: t_sim = {t:.4f} s, t_ana = {t_ana:.4f} s\")\n\n# Diagramm\nfig = go.Figure()\nfig.add_trace(go.Scatter(x=MU_G_WERTE, y=t_sim_liste,\n                         mode='lines+markers', name='Simulation'))\nfig.add_trace(go.Scatter(x=MU_G_WERTE, y=t_ana_liste,\n                         mode='lines', name='Analytisch',\n                         line=dict(dash='dash')))\nfig.update_layout(\n    title=\"Bewegungszeit als Funktion von μ_G\",\n    xaxis_title=\"Gleitreibungskoeffizient μ_G\",\n    yaxis_title=\"Bewegungszeit (s)\"\n)\nfig.show()\n\n# Prozentuale Änderung pro Δμ_G = 0.05\nfor i in range(1, len(MU_G_WERTE)):\n    delta = (t_sim_liste[i] - t_sim_liste[i-1]) / t_sim_liste[i-1] * 100\n    print(f\"μ_G {MU_G_WERTE[i-1]:.2f}→{MU_G_WERTE[i]:.2f}: \"\n          f\"Δt = {delta:+.1f} %\")","position":{"start":{"line":300,"column":1},"end":{"line":358,"column":1}},"key":"uuZYu6YsZp"},{"type":"paragraph","position":{"start":{"line":360,"column":1},"end":{"line":364,"column":1}},"children":[{"type":"text","value":"Die Abhängigkeit ist nicht linear: Bei kleinen μ_G-Werten steigt die\nBewegungszeit stärker pro Einheit als bei großen. Das liegt daran, dass die\nBewegungszeit von ","position":{"start":{"line":360,"column":1},"end":{"line":360,"column":1}},"key":"eYlGAA1Xaz"},{"type":"inlineCode","value":"1/sqrt(a)","position":{"start":{"line":360,"column":1},"end":{"line":360,"column":1}},"key":"NP8mnRIah0"},{"type":"text","value":" abhängt, was eine nichtlineare Funktion von\nμ_G ist. Simulation und Analytik stimmen sehr gut überein (Abweichung unter\n0.3 %).","position":{"start":{"line":360,"column":1},"end":{"line":360,"column":1}},"key":"f2ybwS9PmJ"}],"key":"C7NZvSS9pW"}],"class":"tip dropdown","key":"Zoxx002Vfk"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Übung 9.6 (Mini-Projekt)","position":{"start":{"line":367,"column":1},"end":{"line":367,"column":1}},"key":"ioYPr7BMz2"}],"key":"rGgd5cogMZ"},{"type":"paragraph","position":{"start":{"line":369,"column":1},"end":{"line":369,"column":1}},"children":[{"type":"strong","position":{"start":{"line":369,"column":1},"end":{"line":369,"column":1}},"children":[{"type":"text","value":"Vollständige Ursina-Simulation des eigenen Objekts","position":{"start":{"line":369,"column":1},"end":{"line":369,"column":1}},"key":"CAusaRxHAa"}],"key":"fznxzVl