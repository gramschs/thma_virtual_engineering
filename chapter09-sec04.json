}°\")\n\n# Schwerlastrolle auf Stahl, θ = 12°\nm, mu_h, mu_g, theta, G = 5.0, 0.15, 0.10, math.radians(12), 9.81\nF_N = m * G * math.cos(theta)\nF_H = m * G * math.sin(theta)\nF_haft_max = mu_h * F_N\n\nprint(f\"\\nSchwerlastrolle (θ=12°, Stahl):\")\nif F_H > F_haft_max:\n    F_gleit = mu_g * F_N\n    a       = (F_H - F_gleit) / m\n    print(f\"  Gleitet: F_netto = {F_H - F_gleit:.3f} N, a = {a:.3f} m/s²\")\nelse:\n    print(f\"  Haftet: F_H={F_H:.3f} N < F_Haft,max={F_haft_max:.3f} N\")\n\nprint(f\"\\nHolzeisenbahn: θ_krit = {math.degrees(math.atan(0.40)):.1f}°\")","position":{"start":{"line":58,"column":1},"end":{"line":87,"column":1}},"key":"T5UuLM5cWh"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"Ausgabe:","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"TATn0xt7xg"}],"key":"AsC8ggGUD3"},{"type":"code","lang":"","value":"Kritische Winkel:\n  Stahl auf Stahl: θ_krit = 8.5°\n  Gummi auf Beton: θ_krit = 38.7°\n  Holz auf Holz:   θ_krit = 21.8°\n\nSchwerlastrolle (θ=12°, Stahl):\n  Gleitet: F_netto = 5.400 N, a = 1.080 m/s²\n\nHolzeisenbahn: θ_krit = 21.8°","position":{"start":{"line":90,"column":1},"end":{"line":100,"column":1}},"key":"pelQePxGyh"}],"class":"tip dropdown","key":"HhjOU74WcV"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Übung 9.3 (✩✩)","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"msoHgeeIiR"}],"key":"ozIdlpceZm"},{"type":"paragraph","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"strong","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"Zustandsübergang systematisch untersuchen","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"XiqRyO6KsU"}],"key":"JmhqdSje40"}],"key":"YGJ34Ngk8X"},{"type":"paragraph","position"