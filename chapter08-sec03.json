,\n    position = Vec3(0, 0, 0)\n)\n\n# Kugel\nkugel = Entity(\n    model    = 'sphere',\n    color    = color.red,\n    scale    = 2 * KUGELRADIUS,                     # scale = Durchmesser\n    position = Vec3(START_X, KUGELRADIUS + 0.01, 0)\n)","visibility":"show","key":"P0DQkx0NGh"},{"type":"outputs","id":"0C60Em5KcibgRYpHEmeGQ","children":[],"visibility":"show","key":"XxZLnaDLUq"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"oDOcOyzARk"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Schritt 4: Anzeige und Kamera","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"eB5POF82yb"}],"identifier":"schritt-4-anzeige-und-kamera","label":"Schritt 4: Anzeige und Kamera","html_id":"schritt-4-anzeige-und-kamera","implicit":true,"key":"Dr0Y5xRrqw"}],"key":"ymAuply47W"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"anzeige = Text(\n    text     = 't = 0.000 s | v = 0.000 m/s',\n    position = (-0.85, 0.45),\n    scale    = 1.2,\n    color    = color.black\n)\n\nEditorCamera()","visibility":"show","key":"T6s4bJlPWw"},{"type":"outputs","id":"sfCFJox7E1v8Vfmf3DtUA","children":[],"visibility":"show","key":"JXJmUmHPzu"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"a2vCG9TdBx"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"Schritt 5: Anfangszustand","position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"key":"JOe2tp0Hha"}],"identifier":"schritt-5-anfangszustand","label":"Schritt 5: Anfangszustand","html_id":"schritt-5-anfangszustand","implicit":true,"key":"ASBKWCiqFG"}],"key":"fmWGUxcSLO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"geschwindigkeit = 0.0\nt_sim           = 0.0","visibility":"show","key":"to6KbuEHUA"},{"type":"outputs","id":"sDZP9o-SRMl7xLWzx1_Hs","children":[],"visibility":"show","key":"d1V553lkRv"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"MPvRJQmc9F"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"Schritt 6: Das vollständige Skript","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"kb7KNkj6rs"}],"identifier":"schritt-6-das-vollst-ndige-skript","label":"Schritt 6: Das vollständige Skript","html_id":"schritt-6-das-vollst-ndige-skript","implicit":true,"key":"saFEE4EfPN"},{"type":"paragraph","position":{"start":{"line":132,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"text","value":"Jetzt fügen wir alle Bausteine zu einem lauffähigen Skript zusammen. Alles\nzusammen in eine Datei, zum Beispiel ","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"Q1pfms5vDK"},{"type":"inlineCode","value":"kugelbahn.py","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"nuiEAjf5yM"},{"type":"text","value":":","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"yYCzW9hI1k"}],"key":"k4QtpYnP2R"}],"key":"gXPKsbFckg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from ursina import *\nimport math\n\n# --- Anwendung ---\napp = Ursina(title='Kugelbahn: Einfache Rampe')\nwindow.size = Vec2(1200, 700)\nwindow.color = color.white\n\n# --- Parameter ---\nNEIGUNGSWINKEL = 15.0\nBAHNLAENGE     = 1.2\nKUGELRADIUS    = 0.04\nG              = 9.81\nA_X            = G * math.sin(math.radians(NEIGUNGSWINKEL))\nS_EFF          = BAHNLAENGE - 2 * KUGELRADIUS\nSTART_X        = -(BAHNLAENGE / 2) + KUGELRADIUS\nENDE_X         =  (BAHNLAENGE / 2) - KUGELRADIUS\n\n# --- Objekte ---\nEntity(model='cube', color=color.gray,\n       scale=Vec3(BAHNLAENGE, 0.02, 0.12), position=Vec3(0, 0, 0))\n\nkugel = Entity(model='sphere', color=color.red,\n               scale=2*KUGELRADIUS,\n               position=Vec3(START_X, KUGELRADIUS + 0.01, 0))\n\nanzeige = Text(text='', position=(-0.85, 0.45), scale=1.2, color=color.black)\n\nEditorCamera()\n\n# --- Anfangszustand ---\ngeschwindigkeit = 0.0\nt_sim           = 0.0\nlaeuft          = True\n\n# --- Animationsschleife ---\ndef update():\n    global geschwindigkeit, t_sim, laeuft\n\n    if not laeuft:\n        return\n    \n    # Abbruch\n    if kugel.x >= ENDE_X:\n        laeuft = False\n        print(f'Bewegungszeit: {t_sim:.4f} s')\n        print(f'Endgeschwindigkeit: {geschwindigkeit:.4f} m/s')\n\n    # Euler-Cromer-Verfahren: erst Geschwindigkeit, dann Position\n    geschwindigkeit += A_X * time.dt\n    kugel.x         += geschwindigkeit * time.dt\n    t_sim           += time.dt\n\n    # Anzeige\n    anzeige.text = f't = {t_sim:.3f} s | v = {geschwindigkeit:.3f} m/s'\n\napp.run()","visibility":"show","key":"cWjPgTKxxE"},{"type":"outputs","id":"t9J6oF40xsSce6TyHS68Z","children":[],"visibility":"show","key":"GRb7LSTyHj"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"rKtOdfUKlv"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":196,"column":1},"end":{"line":201,"column":1}},"children":[{"type":"text","value":"Die Reihenfolge “erst Geschwindigkeit, dann Position” ist das\n","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"glbV7JAHjr"},{"type":"strong","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"children":[{"type":"text","value":"Euler-Cromer-Verfahren","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"Q2htKZPRL3"}],"key":"J1PmgSDpAn"},{"type":"text","value":" (symplektischer Euler). Es ist energieerhaltender\nals der klassische explizite Euler, bei dem die Position m