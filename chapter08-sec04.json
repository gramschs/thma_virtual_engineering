unktion: Zylinder mit Mittelpunkt im Ursprung, entlang y-Achse\ndef zylinder_y(radius, hoehe):\n    return Cylinder(\n        radius = radius,\n        height = hoehe,\n        start  = -hoehe/2,   # von -h/2 bis +h/2 -> Mittelpunkt bei y = 0\n        direction = (0, 1, 0)\n    )\n\n# Führungsschienen: entlang x-Achse (y-Zylinder um z-Achse gedreht)\nschiene_links = Entity(\n    model    = zylinder_y(SCHIENEN_RADIUS, SCHIENEN_LAENGE),\n    color    = color.gray,\n    rotation = Vec3(0, 0, 90),                 # y -> x\n    position = Vec3(0, 0, +SCHIENEN_ABSTAND)\n)\n\nschiene_rechts = Entity(\n    model    = zylinder_y(SCHIENEN_RADIUS, SCHIENEN_LAENGE),\n    color    = color.gray,\n    rotation = Vec3(0, 0, 90),\n    position = Vec3(0, 0, -SCHIENEN_ABSTAND)\n)\n\n# Querstreben: entlang z-Achse (y-Zylinder um x-Achse gedreht)\nquer_pos_x = [-0.4, 0.0, 0.4]\nfor x in quer_pos_x:\n    Entity(\n        model    = zylinder_y(SCHIENEN_RADIUS, 2 * SCHIENEN_ABSTAND),\n        color    = color.gray,\n        rotation = Vec3(90, 0, 0),            # y -> z\n        position = Vec3(x, 0, 0)\n    )\n\n# Kugel mittig auf den Schienen\nkugel = Entity(\n    model    = 'sphere',\n    color    = color.red,\n    scale    = 2 * KUGELRADIUS,\n    position = Vec3(0, SCHIENEN_RADIUS + KUGELRADIUS, 0)\n)\n\nEditorCamera()\napp.run()","position":{"start":{"line":207,"column":1},"end":{"line":266,"column":1}},"key":"kIpyrYLkjK"}],"class":"tip dropdown","key":"VXP7ENzaf4"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Übung 8.5 (Projekt)","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"key":"sEhqOiPWiD"}],"key":"IttKyjtFxJ"},{"type":"paragraph","position":{"start":{"line":271,"column":1},"end":{"line":271,"column":1}},"children":[{"type":"strong","position":{"start":{"line":271,"column":1},"end":{"line":271,"column":1}},"children":[{"type":"text","value":"Mein Objekt in Bewegung: Parameter variieren","position":{"st