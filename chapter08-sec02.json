radians(NEIGUNGSWINKEL))\n\ngeschwindigkeit = 0.0   # startet aus dem Stillstand\n\ndef update():\n    global geschwindigkeit\n\n    # Euler-Cromer-Verfahren: erst Geschwindigkeit, dann Position\n    geschwindigkeit += A_X * time.dt\n    kugel.x         += geschwindigkeit * time.dt\n\nEditorCamera()\napp.run()","visibility":"show","key":"XLmQuQggKI"},{"type":"outputs","id":"MxfC-eyIEc-a5n92d2pHK","children":[],"visibility":"show","key":"EIR5e5ZpgW"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"CRJPjqfpey"},{"type":"block","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Mini-Übung","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"mGxBRTzTM7"}],"key":"ITG6Ek8H8q"},{"type":"paragraph","position":{"start":{"line":175,"column":1},"end":{"line":176,"column":1}},"children":[{"type":"text","value":"Modifizieren Sie das Skript so, dass die Kugel bei ","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"hifuiwbNu0"},{"type":"inlineCode","value":"x = 1.0","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"RRUAMOOKKK"},{"type":"text","value":" wirklich stoppt.\nDer korrekte Weg ist, die Abbruchbedingung ","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"IO5HEm7Mmo"},{"type":"strong","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"children":[{"type":"text","value":"vor","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"ee9NKkJjxM"}],"key":"goz3hpAP08"},{"type":"text","value":" der Integration zu prüfen:","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"VRW2Eq3lbx"}],"key":"XV0y1Gh8pB"},{"type":"code","lang":"python","value":"def update():\n    global geschwindigkeit\n\n    if kugel.x >= 1.0:\n        return   # sofort zurück, keine weitere Physik\n\n    geschwindigkeit += A_X * time.dt\n