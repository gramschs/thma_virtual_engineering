n":{"start":{"line":287,"column":1},"end":{"line":287,"column":1}},"key":"gKCTcNW3XG"}],"key":"stsYLzZCeV"}],"class":"tip","key":"IO2cjNbzo6"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Hinweise zum Einstieg","position":{"start":{"line":291,"column":1},"end":{"line":291,"column":1}},"key":"IjHTvakIWV"}],"key":"gJqI1PVfPi"},{"type":"paragraph","position":{"start":{"line":294,"column":1},"end":{"line":294,"column":1}},"children":[{"type":"strong","position":{"start":{"line":294,"column":1},"end":{"line":294,"column":1}},"children":[{"type":"text","value":"Translatorisch:","position":{"start":{"line":294,"column":1},"end":{"line":294,"column":1}},"key":"Wi1BV59pbJ"}],"key":"t0SEQFcWhq"}],"key":"rfxEYqKHZZ"},{"type":"code","lang":"python","value":"# Diese Zeilen sind Ihr Ausgangspunkt:\nA_X        = 2.0     # Beschleunigung in m/s²  → Ihren Wert einsetzen\nBAHNLAENGE = 1.0     # Länge der Bahn in m     → Ihren Wert einsetzen\nKUGELRADIUS = 0.04   # Radius Ihres Objekts    → Ihren Wert einsetzen","position":{"start":{"line":295,"column":1},"end":{"line":300,"column":1}},"key":"qzvdUuv5DV"},{"type":"paragraph","position":{"start":{"line":302,"column":1},"end":{"line":302,"column":1}},"children":[{"type":"strong","position":{"start":{"line":302,"column":1},"end":{"line":302,"column":1}},"children":[{"type":"text","value":"Rotatorisch:","position":{"start":{"line":302,"column":1},"end":{"line":302,"column":1}},"key":"sd48QlwXFf"}],"key":"XIJX9ttItO"}],"key":"u2Ii9YUPAe"},{"type":"code","lang":"python","value":"from ursina import *\n\napp = Ursina(title='Mein Objekt: Rotation')\nwindow.color = color.white\n\nALPHA       = 90.0    # Winkelbeschleunigung in Grad/s²\nZIEL_WINKEL = 720.0   # Zieldrehung in Grad (720 = zwei Umdrehungen)\n\nobjekt = Entity(model='cube', color=color.orange, scale=0.3)\nanzeige = Text(text='', position=(-0.85, 0.45), scale=1.2, color=color.black)\n\nwinkelgeschw = 0.0       # ω in Grad/s\nwinkel       = 0.0       # φ in Grad\nt_sim        = 0.0\nlaeuft       = True\n\ndef update():\n    global winkelgeschw, winkel, t_sim, laeuft\n    if not laeuft:\n        return\n\n    dt = time.dt\n\n    # Euler-Cromer\n    winkelgeschw += ALPHA * dt\n    winkel       += winkelgeschw * dt\n    t_sim        += dt\n\n    if winkel >= ZIEL_WINKEL:\n        winkel = ZIEL_WINKEL\n        laeuft = False\n        print(f'Zeit für {ZIEL_WINKEL}°: {t_sim:.3f} s')\n\n    objekt.rotation_y = winkel\n    anzeige.text      = f't={t_sim:.2f}s | ω={winkelgeschw:.1f}°/s'\n\napp.run()","position":{"start":{"line":303,"column":1},"end":{"line":341,"column":1}},"key":"GehTR4lH7v"}],"class":"tip dropdown","key":"gKItM65fs1"}],"key":"XadNr3oIhh"}],"key":"P2p3Sr6JoZ"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"8.3 Ursina: Erste Schritte und einfache Animation","url":"/chapter08-sec03","group":"8. 3D-Simulation mit Python"},"next":{"title":"9.1 Welche Kräfte wirken auf die Kugel?","url":"/chapter09-sec01","group":"9. Von der Kraft zur Bewegung"}}},"domain":"http://localhost:3000"}