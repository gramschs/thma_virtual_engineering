{"line":98,"column":1},"end":{"line":98,"column":1}},"key":"Jrn7g4M75N"}],"key":"bjRrLvMncY"},{"type":"code","lang":"python","value":"from ursina import *\n\napp = Ursina()\n\n# Rampe als Hintergrund\nEntity(model='cube', color=color.gray,\n       scale=Vec3(2.0, 0.02, 0.15), position=Vec3(0, -0.05, 0))\n\n# Kugel\nkugel = Entity(model='sphere', color=color.red,\n               scale=0.08, position=Vec3(-1.0, 0.05, 0))\n\n# Physikalische Größe (Geschwindigkeit in x- und y-Richtung)\nGESCHWINDIGKEIT = Vec3(0.3, 0.2, 0)\n\ndef update():\n    kugel.position += GESCHWINDIGKEIT * time.dt\n\nEditorCamera()\napp.run()","position":{"start":{"line":101,"column":1},"end":{"line":122,"column":1}},"key":"k3V9GUeBYH"},{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":127,"column":1}},"children":[{"type":"text","value":"Die Kugel bewegt sich schräg nach rechts oben: 0.3 m/s in x-Richtung und\n0.2 m/s in y-Richtung. Sie verlässt die Rampe nach oben, weil die Rampe keine\nphysikalische Wirkung auf die Kugel hat, sondern nur ein visuelles Objekt ist.\nDas Physikmodell (Normalkraft, Reibung) kommt erst in Kapitel 9 dazu.","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"bQ8vMyY7g7"}],"key":"BbXKjIarfB"},{"type":"paragraph","position":{"start":{"line":129,"column":1},"end":{"line":132,"column":1}},"children":[{"type":"text","value":"Wichtig: ","position":{"start":{"line":129,"column":1},"end":{"line":129,"column":1}},"key":"VIEhdY2nad"},{"type":"inlineCode","value":"kugel.position += Vec3(...) * time.dt","position":{"start":{"line":129,"column":1},"end":{"line":129,"column":1}},"key":"jiAN3tX27i"},{"type":"text","value":" funktioniert, weil beide\nSeiten denselben Typ haben (Vec3). Das ursprüngliche ","position":{"start":{"line":129,"column":1},"end":{"line":129,"column":1}},"key":"vkrvMCVsFC"},{"type":"inlineCode","value":"kugel.x += Vec3(...) * time.dt","position":{"start":{"line":129,"column":1},"end":{"line":129,"column"