,\n    position = Vec3(0, 0, 0)\n)\n\n# Kugel\nkugel = Entity(\n    model    = 'sphere',\n    color    = color.red,\n    scale    = 2 * KUGELRADIUS,                     # scale = Durchmesser\n    position = Vec3(START_X, KUGELRADIUS + 0.01, 0)\n)","visibility":"show","key":"fLrEm9N623"},{"type":"outputs","id":"s_LOpOykFSxvCtqfir1cq","children":[],"visibility":"show","key":"OSz8XTvfU4"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"lJcd0oGtbG"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Schritt 4: Anzeige und Kamera","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"OLcm7d36WW"}],"identifier":"schritt-4-anzeige-und-kamera","label":"Schritt 4: Anzeige und Kamera","html_id":"schritt-4-anzeige-und-kamera","implicit":true,"key":"eYfArBqaZC"}],"key":"VCHvxnHxZq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"anzeige = Text(\n    text     = 't = 0.000 s | v = 0.000 m/s',\n    position = (-0.85, 0.45),\n    scale    = 1.2,\n    color    = color.black\n)\n\nEditorCamera()","visibility":"show","key":"xeuSgJ7gOm"},{"type":"outputs","id":"9dsxCJe61uzZr_XeWygd-","children":[],"visibility":"show","key":"g74lVlP4Bu"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"uKoclcai0U"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"Schritt 5: Anfangszustand","position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"key":"Su9wnV3eW9"}],"identifier":"schritt-5-anfangszustand","label":"Schritt 5: Anfangszustand","html_id":"schritt-5-anfangszustand","implicit":true,"key":"NnK9y58fbn"}],"key":"zsvi8xc66V"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"geschwindigkeit = 0.0\nt_sim           = 0.0","visibility":"show","key":"cK2eZe0WQ8"},{"type":"outputs","id":"ww6EQBqh_60jpWqsjoptA","children":[],"visibility":"show","key":"mb5pIh5tce"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"yCCCjAcTmN"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"Schritt 6: Das vollständige Skript","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"aHUpkKISMY"}],"identifier":"schritt-6-das-vollst-ndige-skript","label":"Schritt 6: Das vollständige Skript","html_id":"schritt-6-das-vollst-ndige-skript","implicit":true,"key":"mnjkbXBow6"},{"type":"paragraph","position":{"start":{"line":132,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"text","value":"Jetzt fügen wir alle Bausteine zu einem lauffähigen Skript zusammen. Alles\nzusammen in eine Datei, zum Beispiel ","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"GRO9lB0U5a"},{"type":"inlineCode","value":"kugelbahn.py","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"EDBV5ONBtF"},{"type":"text","value":":","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"rkLebg1DsT"}],"key":"lzUBK8gee4"}],"key":"BUE6SKWf37"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from ursina import *\nimport math\n\n# --- Anwendung ---\napp = Ursina(title='Kugelbahn: Einfache Rampe')\nwindow.size = Vec2(1200, 700)\nwindow.color = color.white\n\n# --- Parameter ---\nNEIGUNGSWINKEL = 15.0\nBAHNLAENGE     = 1.2\nKUGELRADIUS    = 0.04\nG              = 9.81\nA_X            = G * math.sin(math.radians(NEIGUNGSWINKEL))\nS_EFF          = BAHNLAENGE - 2 * KUGELRADIUS\nSTART_X        = -(BAHNLAENGE / 2) + KUGELRADIUS\nENDE_X         =  (BAHNLAENGE / 2) - KUGELRADIUS\n\n# --- Objekte ---\nEntity(model='cube', color=color.gray,\n       scale=Vec3(BAHNLAENGE, 0.02, 0.12), position=Vec3(0, 0, 0))\n\nkugel = Entity(model='sphere', color=color.red,\n               scale=2*KUGELRADIUS,\n               position=Vec3(START_X, KUGELRADIUS + 0.01, 0))\n\nanzeige = Text(text='', position=(-0.85, 0.45), scale=1.2, color=color.black)\n\nEditorCamera()\n\n# --- Anfangszustand ---\ngeschwindigkeit = 0.0\nt_sim           = 0.0\nlaeuft          = True\n\n# --- Animationsschleife ---\ndef update():\n    global geschwindigkeit, t_sim, laeuft\n\n    if not laeuft:\n        return\n    \n    # Abbruch\n    if kugel.x >= ENDE_X:\n        laeuft = False\n        print(f'Bewegungszeit: {t_sim:.4f} s')\n        print(f'Endgeschwindigkeit: {geschwindigkeit:.4f} m/s')\n\n    # Euler-Cromer-Verfahren: erst Geschwindigkeit, dann Position\n    geschwindigkeit += A_X * time.dt\n    kugel.x         += geschwindigkeit * time.dt\n    t_sim           += time.dt\n\n    # Anzeige\n    anzeige.text = f't = {t_sim:.3f} s | v = {geschwindigkeit:.3f} m/s'\n\napp.run()","visibility":"show","key":"OyUkjw9PPY"},{"type":"outputs","id":"NCuIWjEmZttSLrbdMFzm5","children":[],"visibility":"show","key":"JR1gRh9PoY"}],"data":{"tags":["skip-execution"]},"visibility":"show","key":"G9hM8frjMS"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":196,"column":1},"end":{"line":201,"column":1}},"children":[{"type":"text","value":"Die Reihenfolge “erst Geschwindigkeit, dann Position” ist das\n","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"OMUnDHWQjD"},{"type":"strong","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"children":[{"type":"text","value":"Euler-Cromer-Verfahren","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"R7NqGcumqV"}],"key":"J1VIkHKB47"},{"type":"text","value":" (symplektischer Euler). Es ist energieerhaltender\nals der klassische explizite Euler, bei dem die Position m