"start":{"line":225,"column":1},"end":{"line":225,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Welche zwei Druckfehler sind aufgetreten?","position":{"start":{"line":225,"column":1},"end":{"line":225,"column":1}},"key":"tXzWSOsNWi"}],"key":"Br1m0FeVQc"}],"key":"lgMtTPmNFf"},{"type":"listItem","spread":true,"position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Nennen Sie für jeden Fehler eine gezielte Parameteränderung.","position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"key":"VdN6PF2TPE"}],"key":"UaK9bEJI6z"}],"key":"nJoHWfNvI7"},{"type":"listItem","spread":true,"position":{"start":{"line":227,"column":1},"end":{"line":228,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Könnten beide Änderungen gleichzeitig vorgenommen werden, ohne einen neuen\nFehler zu riskieren?","position":{"start":{"line":227,"column":1},"end":{"line":227,"column":1}},"key":"dGzRQakl3K"}],"key":"S3eiF45UZ5"}],"key":"YRnBOxulud"}],"key":"dPB5PicSHP"}],"class":"tip","key":"gusEN8qwOS"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Lösung","position":{"start":{"line":231,"column":1},"end":{"line":231,"column":1}},"key":"gzUeZn4TE4"}],"key":"SAKOJL9TrG"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":234,"column":1},"end":{"line":247,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":234,"column":1},"end":{"line":236,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":234,"column":1},"end":{"line":235,"column":1}},"children":[{"type":"text","value":"Stringing (Fäden in der Rille) und Überextrusion (aufgeblähte, unebene\nOberfläche).","position":{"start":{"line":234,"column":1},"end":{"line":234,"column":1}},"key":"Rov46SMChM"}],"key":"xIhOEnqXO9"}],"key":"SMuaFPOLP1"},{"type":"listItem","spread":true,"position":{"start":{"line":237,"column":1},"end":{"line":241,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":237,"column":1},"end":{"line":240,"column":1}},"children":[{"type":"text","value":"Stringing: Drucktemperatur von 215 °C auf etwa 205 bis 208 °C senken und\ndie Retraktion im Slicer prüfen beziehungsweise leicht erhöhen.\nÜberextrusion: Den Flow-Rate-Wert im Slicer auf 95 bis 98 Prozent senken\noder die E-Steps des Extruders kalibrieren.","position":{"start":{"line":237,"column":1},"end":{"line":237,"column":1}},"key":"vrVHoQFkoo"}],"key":"hEnm1cG2et"}],"key":"Wi99ENp9Hu"},{"type":"listItem","spread":true,"position":{"start":{"line":242,"column":1},"end":{"line":247,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":242,"column":1},"end":{"line":247,"column":1}},"children":[{"type":"text","value":"Ja, beide Änderungen können gleichzeitig vorgenommen werden. Die\nTemperaturabsenkung bekämpft das Stringing, ohne die Extrusion direkt\nzu beeinflussen. Die Flow-Rate-Korrektur ist von der Temperatur unabhängig.\nAllerdings sollte man die Temperatur nicht zu stark senken, weil sonst\nUnterextrusion oder Layer Separation entstehen kann. Ein neuer Testdruck\nmit den geänderten Werten ist daher empfehlenswert.","position":{"start":{"line":242,"column":1},"end":{"line":242,"column":1}},"key":"mZXm0yUhJn"}],"key":"KNjAflwpCo"}],"key":"cH24QpHVGE"}],"key":"vDfzkbQlZF"}],"class":"tip dropdown","key":"hCc6YBNHTE"},{"type":"details","children":[{"type":"summary","children":[{"type":"text","value":"Video “3D-Druck Probleme: Lösungen-Tipps!” von AMPrO 3D - Erfolg mit 3D-Druck","position":{"start":{"line":250,"column":1},"end":{"line":250,"column":1}},"key":"if8cbqBTri"}],"key":"qtE0GhhdXY"},{"type":"iframe","src":"https://www.youtube.com/embed/WL3T_ijUUs8","width":"100%","title":"3D-Druck Probleme: Lösungen-Tipps! Springe mit Hilfe der Zeitschiene zu genau\ndeinem Problem!","key":"guVyAAtBla"}],"key":"Y0PKxohagG"},{"type":"heading","depth":2,"position":{"start":{"line":258,"column":1},"end":{"line":258,"column":1}},"children":[{"type":"text","value":"Zusammenfassung und Ausblick","position":{"start":{"line":258,"column":1},"end":{"line":258,"column":1}},"key":"ShskCoilJO"}],"identifier":"zusammenfassung-und-ausblick","label":"Zusammenfassung und Ausblick","html_id":"zusammenfassung-und-ausblick","implicit":true,"key":"ah6gqji4wF"},{"type":"paragraph","position":{"start":{"line":260,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"In diesem Abschnitt haben wir fünf typische FDM-Druckfehler kennengelernt:\nWarping durch Schrumpfungsspannungen beim Abkühlen, Stringing durch\nunkontrollierten Materialfluss bei Travel-Moves, Unterextrusion und\nÜberextrusion durch falsch dosiertes Material und Layer Separation durch\nunzureichende Schichtverbindung. Jeder Fehler lässt sich auf einen oder\nmehrere der Parameter aus Abschnitt 7.1 zurückführen, und jeder hat eine\nklare, gezielte Abhilfemaßnahme. Für die Kugelbahn sind Warping und Layer\nSeparation besonders kritisch, weil sie die Funktionalität direkt gefährden.","position":{"start":{"line":260,"column":1},"end":{"line":260,"column":1}},"key":"kVvcTtjgGR"}],"key":"wMrOSOHjBD"},{"type":"paragraph","position":{"start":{"line":269,"column":1},"end":{"line":272,"column":1}},"children":[{"type":"text","value":"Im nächsten Abschnitt öffnen wir den Slicer und setzen das Gelernte praktisch\num: Wir importieren unser bereinigtes Mesh, wählen die Druckorientierung,\nstellen die fünf Schlüsselparameter ein und lesen in der Layer-Vorschau ab,\nob kritische Stellen der Kugelbahn gut versorgt sind.","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"key":"zWzygq77Ug"}],"key":"cH44R32zJJ"}],"key":"OHMPu3J47j"}],"key":"adbh25S5tg"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"7.1 Wie funktioniert FDM-3D-Druck, und welche Parameter entscheiden?","url":"/chapter07-sec01","group":"7. Vom Mesh zum gedruckten Objekt"},"next":{"title":"7.3 Vom Mesh zum optimierten G-Code: Schritt für Schritt","url":"/chapter07-sec03","group":"7. Vom Mesh zum gedruckten Objekt"}}},"domain":"http://localhost:3000"}